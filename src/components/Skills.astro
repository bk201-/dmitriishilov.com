---
interface SkillGroup { category: string; items: string[] }
interface Props { skills: SkillGroup[] }
const { skills } = Astro.props;
---
<section class="cv-section">
  <h2 class="cv-section-title">Skills</h2>
  {skills.map((g) => (
    <div class="skill-group">
      <span class="skill-category">{g.category}:</span>
      <span class="skill-items">{g.items.join(', ')}</span>
    </div>
  ))}
</section>
<style>
  .cv-section { margin-bottom: 16px; }
  .cv-section-title { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.08em; color: #2563eb; border-bottom: 1px solid #e5e7eb; padding-bottom: 4px; margin-bottom: 8px; font-weight: 600; }
  .skill-group { font-size: 0.82rem; margin-bottom: 4px; line-height: 1.45; }
  .skill-category { font-weight: 600; color: #1a1a1a; }
  .skill-items { color: #555; }
</style>