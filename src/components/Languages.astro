---
interface Lang { name: string; level: string }
interface Props { languages: Lang[] }
const { languages } = Astro.props;
---
<section class="cv-section">
  <h2 class="cv-section-title">Languages</h2>
  {languages.map((l) => (
    <div class="lang">
      <span class="lang-name">{l.name}</span>
      <span class="lang-level"> — {l.level}</span>
    </div>
  ))}
</section>
<style>
  .cv-section { margin-bottom: 16px; }
  .cv-section-title { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.08em; color: #2563eb; border-bottom: 1px solid #e5e7eb; padding-bottom: 4px; margin-bottom: 8px; font-weight: 600; }
  .lang { font-size: 0.82rem; margin-bottom: 3px; }
  .lang-name { font-weight: 600; color: #1a1a1a; }
  .lang-level { color: #555; }
</style>