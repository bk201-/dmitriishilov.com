---
interface Contact {
  type: string;
  value: string;
  url?: string;
  icon: string;
}
interface Props {
  name: string;
  title: string;
  photo: string;
  contacts: Contact[];
}
const { name, title, photo, contacts } = Astro.props;
---
<header class="cv-header">
  <img src={photo} alt={name} class="cv-photo" width="100" height="100" />
  <div class="cv-header-info">
    <h1 class="cv-name">{name}</h1>
    <p class="cv-title">{title}</p>
    <div class="cv-contacts">
      {contacts.map((c) => (
        <span class="cv-contact">
          <span class="cv-contact-icon">{c.icon}</span>
          {c.url ? <a href={c.url} target="_blank" rel="noopener">{c.value}</a> : <span>{c.value}</span>}
        </span>
      ))}
    </div>
  </div>
</header>
<style>
  .cv-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 2px solid #2563eb;
  }
  .cv-photo {
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }
  .cv-header-info {
    min-width: 0;
  }
  .cv-name {
    font-size: 1.6rem;
    font-weight: 700;
    color: #1a1a1a;
    line-height: 1.2;
    margin-bottom: 2px;
  }
  .cv-title {
    font-size: 1rem;
    color: #2563eb;
    margin-bottom: 8px;
    font-weight: 500;
  }
  .cv-contacts {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 14px;
    font-size: 0.82rem;
    color: #555;
  }
  .cv-contact {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    white-space: nowrap;
  }
  .cv-contact-icon {
    font-size: 0.9em;
  }
  .cv-contact a {
    color: #555;
  }
  .cv-contact a:hover {
    color: #2563eb;
  }
</style>