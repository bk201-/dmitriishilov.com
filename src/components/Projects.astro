---
interface Project { name: string; url: string; description: string }
interface Props { projects: Project[] }
const { projects } = Astro.props;
---
<section class="cv-section">
  <h2 class="cv-section-title">Projects</h2>
  {projects.map((p) => (
    <div class="project">
      <a href={p.url} target="_blank" rel="noopener" class="project-name">{p.name}</a>
      <span class="project-desc"> — {p.description}</span>
    </div>
  ))}
</section>
<style>
  .cv-section { margin-bottom: 16px; }
  .cv-section-title { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.08em; color: #2563eb; border-bottom: 1px solid #e5e7eb; padding-bottom: 4px; margin-bottom: 8px; font-weight: 600; }
  .project { font-size: 0.82rem; margin-bottom: 6px; line-height: 1.45; }
  .project-name { font-weight: 600; color: #2563eb; }
  .project-desc { color: #555; }
</style>