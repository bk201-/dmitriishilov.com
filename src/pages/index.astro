---
import CVLayout from '../layouts/CVLayout.astro';
import Header from '../components/Header.astro';
import Summary from '../components/Summary.astro';
import Skills from '../components/Skills.astro';
import Experience from '../components/Experience.astro';
import Education from '../components/Education.astro';
import Projects from '../components/Projects.astro';
import Languages from '../components/Languages.astro';
import cv from '../data/cv-en.json';
---
<CVLayout title={`${cv.name} — ${cv.title}`} lang="en">
  <Header slot="header" name={cv.name} title={cv.title} photo={cv.photo} contacts={cv.contacts} />
  <Fragment slot="sidebar">
    <Skills skills={cv.skills} />
    <Languages languages={cv.languages} />
  </Fragment>
  <Fragment slot="content">
    <Summary text={cv.summary} />
    <Experience jobs={cv.experience} />
    <Education items={cv.education} />
    <Projects projects={cv.projects} />
  </Fragment>
</CVLayout>